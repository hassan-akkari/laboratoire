{
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [
    {
      "pattern": "apps/*",
      "changeProcessCWD": true
    },
    {
      "pattern": "packages/*",
      "changeProcessCWD": true
    },
    {
      "directory": ".",
      "changeProcessCWD": true
    }
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "typescript.tsdk": "node_modules/typescript/lib",
  "search.exclude": {
    "**/.next": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/.vercel": true
  }
}
