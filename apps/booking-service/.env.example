# === Database (Neon Postgres) ===
# Create a project at https://neon.tech, copy the pooled connection string.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# === Admin (single-admin MVP, iron-session cookie) ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
# Must be >= 32 chars. Used to seal the admin_session cookie.
ADMIN_SESSION_SECRET=at-least-32-chars-of-random-data-please-change-me

# Note: with DATABASE_URL empty, the app still boots — DB queries return empty
# and the UI shows a setup state. Set DATABASE_URL, then db:push + db:seed.
