# Base URL of the admin API (apps/web-next).
# Dev:  http://localhost:3001
# Prod: https://admin.itshassan.it
# NOTE: the legacy Vite names (VITE_ADMIN_API_BASE / VITE_CAL_LINK) still work —
# next.config.ts maps them as fallbacks, so the existing Vercel env vars need
# no rename. NEXT_PUBLIC_* wins when both are set.
NEXT_PUBLIC_ADMIN_API_BASE=http://localhost:3001

# Cal.com event link (username/slug)
NEXT_PUBLIC_CAL_LINK=itshassan/discovery-call
